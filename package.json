{
  "name": "html-ele",
  "description": "εLε - Native HTMLElement builder from type-safe template literals",
  "version": "0.1.3",
  "author": "Kawanet",
  "bugs": {
    "url": "https://github.com/kawanet/html-ele/issues"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-multi-entry": "^7.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-sucrase": "^5.1.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.7.2",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.6",
    "rollup": "^4.62.0",
    "terser": "^5.48.0",
    "ts-refine": "^0.6.0",
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./types/html-ele.d.ts",
      "require": "./dist/html-ele.cjs",
      "import": "./dist/html-ele.mjs"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "browser/import.js",
    "browser/package.json",
    "dist/html-ele.cjs",
    "dist/html-ele.min.js",
    "dist/html-ele.mjs",
    "dist/package.json",
    "src/*.ts",
    "types/*.d.ts"
  ],
  "homepage": "https://github.com/kawanet/html-ele#readme",
  "keywords": [
    "browser",
    "documentfragment",
    "dom",
    "html",
    "htmlelement",
    "tagged-template",
    "template-literal",
    "typescript",
    "xss"
  ],
  "license": "MIT",
  "main": "./dist/html-ele.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kawanet/html-ele.git"
  },
  "scripts": {
    "build": "make -C builder",
    "fixpack": "fixpack",
    "prepack": "make -C builder is-buildable",
    "prepare": "make -C builder is-not-buildable 2> /dev/null || make -C builder clean all test",
    "test": "make -C builder test",
    "ts-refine": "./node_modules/.bin/ts-refine format && ./node_modules/.bin/ts-refine imports"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./types/html-ele.d.ts"
}
