{
  "name": "html-ele",
  "description": "εLε - Native HTMLElement builder from type-safe template literals",
  "version": "0.0.1",
  "author": "Kawanet",
  "bugs": {
    "url": "https://github.com/kawanet/html-ele/issues"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-multi-entry": "^7.0.0",
    "@rollup/plugin-node-resolve": "^16.0.2",
    "@rollup/plugin-sucrase": "^5.0.2",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.7.2",
    "chai": "^6.2.0",
    "jsdom": "^29.0.0",
    "mocha": "^11.7.4",
    "rollup": "^4.52.4",
    "terser": "^5.44.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "require": "./dist/html-ele.cjs",
      "import": {
        "types": "./types/html-ele.d.ts",
        "default": "./dist/html-ele.mjs"
      }
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/html-ele.cjs",
    "dist/html-ele.min.js",
    "dist/html-ele.mjs",
    "dist/package.json",
    "src/*.ts",
    "types/*.d.ts"
  ],
  "homepage": "https://github.com/kawanet/html-ele#readme",
  "keywords": [
    "browser",
    "documentfragment",
    "dom",
    "html",
    "htmlelement",
    "tagged-template",
    "template-literal",
    "typescript",
    "xss"
  ],
  "license": "MIT",
  "main": "./src/index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kawanet/html-ele.git"
  },
  "scripts": {
    "build": "make -C builder",
    "fixpack": "fixpack",
    "prepare": "make -C builder clean all test",
    "test": "node --test"
  },
  "sideEffects": false,
  "type": "module",
  "types": "types/html-ele.d.ts"
}
